{
  "name": "enocean-assessment-1",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "deps:up": "npx ts-node scripts/deps-up.ts",
    "deps:down": "npx ts-node scripts/deps-down.ts",
    "deps:wait": "npx ts-node scripts/wait-ready.ts",
    "test": "jest --config jest.config.ts",
    "test:integration": "FLUSH_DEBUG_DELAY_MS=200 jest --config jest.integration.config.ts --runInBand --forceExit",
    "test:all": "yarn test && yarn test:integration",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.3.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "yarn@4.9.1"
}
